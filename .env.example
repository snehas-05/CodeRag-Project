# ─────────────────────────────────────────────────────────────────────────────
# CodeRAG — Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# Never commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App Mode ─────────────────────────────────────────────────────────────────
# Use "local" when running backend with uvicorn directly (default for dev).
# Use "docker" when running everything inside Docker Compose.
APP_ENV=local

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=coderag
MYSQL_USER=coderag_user
MYSQL_PASSWORD=coderag_pass
MYSQL_URL=mysql+pymysql://coderag_user:coderag_pass@mysql:3306/coderag
# Port that MySQL is published on your host machine (docker-compose maps this)
MYSQL_HOST_PORT=3307

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Port that ChromaDB is published on your host machine
CHROMA_HOST_PORT=8001

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Storage Paths (inside container) ─────────────────────────────────────────
# When APP_ENV=local these are auto-resolved to local paths by config.py
MODEL_CACHE_DIR=/app/model_cache
REPOS_DIR=/app/repos

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
# Model used for AI reasoning (default: gemini-2.0-flash)
GEMINI_REASONING_MODEL=gemini-2.0-flash

# ── SMTP (Email) ──────────────────────────────────────────────────────────────
# Mailtrap/Gmail settings for Forgot Password OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=72313859@ctuniversity.in
SMTP_PASSWORD=impolhxbtbkaxltq
SMTP_FROM=no-reply@coderag.ai
